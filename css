body {
    text-align: center;
    font-family: Arial;
}

h1 {
    color: darkblue;
}

.directions {
    display: flex;
    justify-content: center;
    margin: 20px;
}

.directions div {
    margin: 10px;
    padding: 20px;
    border: 2px solid black;
    cursor: pointer;
    width: 120px;
    font-size: 18px;
}

button {
    padding: 10px 20px;
    margin: 10px;
    font-size: 16px;
}

.slot {
    display: inline-block;
    padding: 10px;
    margin: 5px;
    width: 60px;
    color: white;
}

.free {
    background-color: green;
}

.occupied {
    background-color: red;
}
